)
plt.title('Customer Segments using DBSCAN (Noise = -1)')
plt.xlabel('Annual Income (k$)')
plt.ylabel('Spending Score (1-100)')
plt.savefig('dbscan_clusters.png')
plt.show()

--- 4.3 3D Visualization using Plotly ---
We use Age, Income, and Score for a 3D view
fig = px.scatter_3d(
df,
x='Age',
