alpha=0.8
)

Plotting Centroids
centroids = scaler.inverse_transform(kmeans_model.cluster_centers_)
plt.scatter(centroids[:, 0], centroids[:, 1], s=300, c='red', marker='*', label='Centroids')

plt.title('Customer Segments using K-Means')
