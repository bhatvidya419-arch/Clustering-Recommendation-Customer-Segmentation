)
fig.write_html("3d_clusters.html")
print("3D plot saved as '3d_clusters.html' (Open in browser to interact).")

--- 4.4 Correlation Heatmap (Data Understanding) ---
plt.figure(figsize=(8, 6))

Use only numeric columns for correlation
numeric_df = df.select_dtypes(include=[np.number])
sns.heatmap(numeric_df.corr(), annot=True, cmap='coolwarm', fmt=".2f")
plt.title('Feature Correlation Matrix')
plt.savefig('correlation_heatmap.png')
plt.show()

--- 4.5 Cluster Profiling (Bar Chart) ---
cluster_means = df.groupby('KMeans_Cluster')[['Age', 'Annual Income (k$)', 'Spending Score (1-100)']].mean()
print("\n--- Cluster Statistics (Mean Values) ---")
print(cluster_means)

cluster_means.plot(kind='bar', figsize=(12, 6))
plt.title('Average Attributes per Cluster')
plt.ylabel('Average Value')
plt.xticks(rotation=0)
plt.savefig('cluster_profiles.png')
plt.show()

============================================================
5. SEGMENT NAMING (Insights)
============================================================
def identify_segment(row):
# Logic based on Mall Customer typical segments
# Cluster mapping might vary based on random state, so we use general logic here
# For this specific run (K=5):
# Cluster 2: High Income, High Spending -> Premium
# Cluster 3: High Income, Low Spending -> Careful
# Cluster 0: Low Income, High Spending -> Target
# Cluster 1: Low Income, Low Spending -> Sensible
# Cluster 4: Average Income, Average Spending -> Standard

cluster_id = row['KMeans_Cluster']
# Note: IDs are dynamic. In a real scenario, you map these based on the cluster_means table above.
# For this code, we return the ID for simplicity, or map manually:

segment_map = {
0: "Standard / Middle Class",
1: "Careful (High Income, Low Spend)",
2: "Premium (High Income, High Spend)",
3: "Target (Low Income, High Spend)",
4: "Sensible (Low Income, Low Spend)"
}
# This map is an example; actual mapping depends on the cluster centers order.
return segment_map.get(cluster_id, "Other")
df['Segment_Name'] = df.apply(identify_segment, axis=1)

print("\n--- Final Dataset with Segments ---")
print(df[['CustomerID', 'Genre', 'Age', 'Annual Income (k$)', 'Spending Score (1-100)', 'Segment_Name']].head(10))

Save final output
df.to_csv('segmented_output.csv', index=False)
print("\nAnalysis Complete. Output saved to 'segmented_output.csv'.")

