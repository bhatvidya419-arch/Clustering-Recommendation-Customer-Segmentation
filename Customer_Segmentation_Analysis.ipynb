# ============================================================
# 1. IMPORT LIBRARIES
# ============================================================
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import plotly.express as px

from sklearn.cluster import KMeans, DBSCAN
from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.metrics import silhouette_score, confusion_matrix, classification_report
from sklearn.decomposition import PCA

import warnings
warnings.filterwarnings('ignore')

# Setting visualization style
plt.style.use('seaborn-v0_8-whitegrid')

# ============================================================
# 2. DATA LOADING & PREPROCESSING
# ============================================================

# Attempt to load dataset. If not found, generate synthetic data for demonstration.
try:
    # Assuming 'Mall_Customers.csv' is in the directory
    df = pd.read_csv('Mall_Customers.csv')
    print("Dataset 'Mall_Customers.csv' loaded successfully.")
except FileNotFoundError:
    print("Dataset file not found. Generating synthetic dataset for demonstration...")
    # Synthetic Data Generation
    np.random.seed(42)
    n_samples = 200
    data = {
        'CustomerID': range(1
, n_samples + 1),
'Genre': np.random.choice(['Male', 'Female'], n_samples),
'Age': np.random.randint(18, 70, n_samples),
'Annual Income (k$)': np.random.randint(15, 140, n_samples),
'Spending Score (1-100)': np.random.randint(1, 100, n_samples)
}
df = pd.DataFrame(data)

--- 2.1 Data Inspection ---
print("\n--- First 5 Rows ---")
print(df.head())

print("\n--- Data Info ---")
print(df.info())

print("\n--- Missing Values Check ---")
print(df.isnull().sum())

--- 2.2 Preprocessing Steps ---
Drop CustomerID as it is irrelevant for clustering
if 'CustomerID' in df.columns:
df_processed = df.drop(['CustomerID'], axis=1)

Encode Categorical Variable 'Genre' (Male: 0, Female: 1)
le = LabelEncoder()
df_processed['Genre'] = le.fit_transform(df_processed['Genre'])

Feature Selection for Clustering
We focus on 'Annual Income' and 'Spending Score' for 2D visualization clarity
We keep Age and Genre for profiling later
X_features = df_processed[['Annual Income (k$)', 'Spending Score (1-100)']]

Feature Scaling (Crucial for Distance-Based Algorithms)
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X_features)

print("\nPreprocessing Complete. Data Scaled.")

============================================================
3. MODEL TRAINING & EVALUATION
============================================================
--- 3.1 K-Means Clustering ---
Step A: Finding Optimal K using the Elbow Method
wcss = [] # Within-Cluster Sum of Squares
k_range = range(1, 11)

for i in k_range:
kmeans = KMeans(n_clusters=i, init='k-means++', random_state=42)
kmeans.fit(X_scaled)
wcss.append(kmeans.inertia_)

Plotting the Elbow Graph
plt.figure(figsize=(10, 5))
plt.plot(k_range, wcss, marker='o', linestyle='--')
plt.title('The Elbow Method to Determine Optimal K')
plt.xlabel('Number of Clusters (K)')
plt.ylabel('WCSS (Inertia)')
plt.savefig('elbow_method.png')
plt.show()

Step B: Training K-Means with Optimal K (Assume K=5 based on Mall Customer data structure)
optimal_k = 5
kmeans_model = KMeans(n_clusters=optimal_k, init='k-means++', random_state=42)
y_kmeans = kmeans_model.fit_predict(X_scaled)

Evaluation Metric: Silhouette Score
kmeans_silhouette = silhouette_score(X_scaled, y_kmeans)
print(f"K-Means Silhouette Score: {kmeans_silhouette:.3f}")

Add Cluster Labels to Dataframe
df['KMeans_Cluster'] = y_kmeans

--- 3.2 DBSCAN Clustering ---
DBSCAN does not require K, but requires epsilon (eps) and min_samples
dbscan = DBSCAN(eps=0.5, min_samples=5)
y_dbscan = dbscan.fit_predict(X_scaled)

Add DBSCAN Labels (-1 represents noise/outliers)
df['DBSCAN_Cluster'] = y_dbscan

Evaluation (ignoring noise points labeled as -1 for valid score if needed)
if len(set(y_dbscan)) > 1:
dbscan_silhouette = silhouette_score(X_scaled, y_dbscan)
print(f"DBSCAN Silhouette Score: {dbscan_silhouette:.3f}")
else:
print("DBSCAN found only one cluster or noise. Parameters might need tuning.")

============================================================
4. VISUALIZATIONS
============================================================
--- 4.1 K-Means Cluster Visualization (2D) ---
plt.figure(figsize=(12, 8))
sns.scatterplot(
